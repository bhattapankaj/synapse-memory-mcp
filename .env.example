# Synapse is fully functional with NO keys (on-device embeddings + demo-mode agent).
# Set these only to enable cloud embeddings or a live LLM agent in the Playground.

# Embedding provider: "local" (default, on-device Transformers.js) or "openai"
SYNAPSE_EMBEDDINGS=local

# Optional: OpenAI-compatible API for the Playground agent and/or cloud embeddings.
# If omitted, the Playground runs in deterministic demo mode and embeddings run locally.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Where the local memory database is stored.
SYNAPSE_DB_PATH=./data/synapse.db
